---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../components/BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import SeriesNav from '../components/SeriesNav.astro';
import TagList from '../components/TagList.astro';
import { site } from '../config/site';
import { getPostFolder, getSeriesNavigation, getSortedPosts } from '../utils/blog';

interface Props {
	post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, tags } = post.data;
const allPosts = await getSortedPosts();
const seriesNav = getSeriesNavigation(allPosts, post);
const folder = getPostFolder(post);
const folderLabel = folder ? (site.folders[folder] ?? folder) : null;
---

<BaseLayout title={`${title} | ${site.title}`} description={description} mainClass="article-page">
	<article>
		<header class="article-header">
			{
				folderLabel && (
					<p class="article-folder">
						<a href="/blog/">文章</a>
						<span class="tag-breadcrumb-sep">/</span>
						<span>{folderLabel}</span>
					</p>
				)
			}
			<time datetime={pubDate.toISOString()}>
				<FormattedDate date={pubDate} />
			</time>
			{
				updatedDate && (
					<p class="updated">
						更新于 <FormattedDate date={updatedDate} />
					</p>
				)
			}
			<h1>{title}</h1>
			<p class="description">{description}</p>
			<TagList tags={tags} class="article-tags" />
		</header>

		{seriesNav && <SeriesNav {...seriesNav} />}

		<div class="prose">
			<slot />
		</div>

		{seriesNav && <SeriesNav {...seriesNav} />}
	</article>
</BaseLayout>
