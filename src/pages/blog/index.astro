---
import BaseLayout from '../../components/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { site } from '../../config/site';
import { getPostsGroupedByFolder, getSortedPosts, postHref } from '../../utils/blog';

const posts = await getSortedPosts();
const groups = site.blog.groupByFolder ? getPostsGroupedByFolder(posts) : null;

function folderLabel(folder: string): string {
	if (folder === '_root') return '其他';
	return site.folders[folder] ?? folder;
}
---

<BaseLayout title={`${site.blog.title} | ${site.title}`} description={site.description} mainClass="wide">
	<header class="page-header">
		<h1>{site.blog.title}</h1>
		<p>
			{site.blog.subtitle(posts.length)}
			{' · '}
			<a href="/tags/">按分类浏览</a>
			{' · '}
			<a href="/series/">按系列浏览</a>
		</p>
	</header>

	{
		groups ? (
			groups.map(({ folder, posts: folderPosts }) => (
				<section class="folder-group">
					<h2 class="folder-group-title">{folderLabel(folder)}</h2>
					<div class="post-grid">
						{folderPosts.map((post, i) => (
							<PostCard
								href={postHref(post)}
								title={post.data.title}
								description={post.data.description}
								pubDate={post.data.pubDate}
								tags={post.data.tags}
								featured={site.blog.featureFirstPost && i === 0 && folder === groups[0]?.folder}
							/>
						))}
					</div>
				</section>
			))
		) : (
			<div class="post-grid">
				{posts.map((post, i) => (
					<PostCard
						href={postHref(post)}
						title={post.data.title}
						description={post.data.description}
						pubDate={post.data.pubDate}
						tags={post.data.tags}
						featured={site.blog.featureFirstPost && i === 0}
					/>
				))}
			</div>
		)
	}
</BaseLayout>
