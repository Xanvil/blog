---
import BaseLayout from '../../components/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { site } from '../../config/site';
import { getSortedPosts } from '../../utils/blog';

const posts = await getSortedPosts();
---

<BaseLayout title={`${site.blog.title} | ${site.title}`} description={site.description} mainClass="wide">
	<header class="page-header">
		<h1>{site.blog.title}</h1>
		<p>
			{site.blog.subtitle(posts.length)}
			{' · '}
			<a href="/tags/">按分类浏览</a>
		</p>
	</header>

	<div class="post-grid">
		{
			posts.map((post, i) => (
				<PostCard
					href={`/blog/${post.id}/`}
					title={post.data.title}
					description={post.data.description}
					pubDate={post.data.pubDate}
					tags={post.data.tags}
					featured={site.blog.featureFirstPost && i === 0}
				/>
			))
		}
	</div>
</BaseLayout>
