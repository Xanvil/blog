---
import { site } from '../config/site';
import FormattedDate from './FormattedDate.astro';

interface Props {
	href: string;
	title: string;
	description: string;
	pubDate: Date;
	featured?: boolean;
}

const { href, title, description, pubDate, featured = false } = Astro.props;
const { showDescription, showReadMore, readMoreLabel } = site.blog;
---

<article class:list={['post-card', { featured }]}>
	<a href={href} class="post-card-link">
		<time datetime={pubDate.toISOString()}>
			<FormattedDate date={pubDate} />
		</time>
		<h2>{title}</h2>
		{showDescription && description && <p>{description}</p>}
		{showReadMore && <span class="read-more">{readMoreLabel}</span>}
	</a>
</article>
