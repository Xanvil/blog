---
import BaseHead from './BaseHead.astro';
import Footer from './Footer.astro';
import Header from './Header.astro';
import LeftAside from './LeftAside.astro';
import RightAside from './RightAside.astro';
import { site } from '../config/site';
import type { CurrentSeries } from '../utils/blog';
import { getAllSeries, getAllTags, getSortedPosts } from '../utils/blog';

interface Props {
	title: string;
	description: string;
	mainClass?: string;
	currentSeries?: CurrentSeries;
}

const { title, description, mainClass, currentSeries } = Astro.props;
const { layout } = site;
const posts = await getSortedPosts();
const tags = layout.showRightAside ? getAllTags(posts).slice(0, layout.rightTagCount) : [];
const series = layout.showRightAside
	? getAllSeries(posts).slice(0, layout.rightSeriesCount)
	: [];
const useThreeColumn = layout.showLeftAside || layout.showRightAside;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body class:list={{ 'layout-three-col': useThreeColumn }}>
		<div class="page">
			<header class="site-header">
				<Header />
			</header>

			<div class:list={['page-body', { 'page-body--three-col': useThreeColumn }]}>
				{layout.showLeftAside && <LeftAside />}
				<main class:list={['page-content', mainClass]}>
					<slot />
				</main>
				{layout.showRightAside && (
					<RightAside tags={tags} series={series} currentSeries={currentSeries} />
				)}
			</div>

			<footer class="site-footer-wrap">
				<Footer />
			</footer>
		</div>
	</body>
</html>
