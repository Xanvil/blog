---
import { postHref } from '../utils/blog';

interface Props {
	name: string;
	slug: string;
	index: number;
	total: number;
	prev: { id: string; data: { title: string } } | null;
	next: { id: string; data: { title: string } } | null;
}

const { name, slug, index, total, prev, next } = Astro.props;
---

<nav class="series-nav" aria-label="系列导航">
	<span class="series-nav-meta">
		<a href={`/series/${slug}/`}>{name}</a>
		<span class="series-nav-index">{index}/{total}</span>
	</span>
	{
		(prev || next) && (
			<div class="series-nav-pager">
				{prev ? (
					<a href={postHref(prev)} class="series-nav-item series-nav-prev" title={prev.data.title}>
						← {prev.data.title}
					</a>
				) : (
					<span class="series-nav-item series-nav-empty" />
				)}
				{next ? (
					<a href={postHref(next)} class="series-nav-item series-nav-next" title={next.data.title}>
						{next.data.title} →
					</a>
				) : (
					<span class="series-nav-item series-nav-empty" />
				)}
			</div>
		)
	}
</nav>
