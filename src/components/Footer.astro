---
import { site } from '../config/site';

const year = new Date().getFullYear();
---

<footer class="site-footer">
	<p>
		{site.footer.copyright(year, site.author)}
		{
			site.footer.links.map((link, i) => (
				<>
					{i === 0 ? ' · ' : ' · '}
					<a href={link.href}>{link.label}</a>
				</>
			))
		}
	</p>
</footer>
