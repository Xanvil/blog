---
import { site } from '../config/site';
import HeaderLink from './HeaderLink.astro';
---

<nav class="site-header-inner">
	<a href="/" class="site-logo">{site.title}</a>
	<div class="nav-links nav-links--mobile">
		{site.nav.map((item) => (
			<HeaderLink href={item.href}>{item.label}</HeaderLink>
		))}
	</div>
</nav>
